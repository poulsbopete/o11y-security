# Copy to .env in this directory (never commit .env)
#
# Prerequisite (recommended): install Elastic Agent Skills from
#   https://github.com/elastic/agent-skills
# then use cloud-setup + cloud-create-project + elasticsearch-authn per SKILLS-FIRST-WORKFLOW.md
#
# Cloud API key: https://cloud.elastic.co/account/keys (Project Admin / Org Owner)
#
# Required: do not leave this empty. Keys often end with "=" — use single quotes:
#   EC_API_KEY='your_key_here'

EC_API_KEY=
EC_BASE_URL=https://api.elastic-cloud.com
EC_REGION=gcp-us-central1

# Optional: lowercase RFC1035-ish prefix for generated project names
A2A_NAME_PREFIX=a2a-lab
