# Copy to .env in this directory (never commit .env)
# Cloud API key: https://cloud.elastic.co/account/keys (Project Admin / Org Owner)

EC_API_KEY=
EC_BASE_URL=https://api.elastic-cloud.com
EC_REGION=gcp-us-central1

# Optional: lowercase RFC1035-ish prefix for generated project names
A2A_NAME_PREFIX=a2a-lab
