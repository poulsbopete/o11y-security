# Copy to .env in this directory (never commit .env)
#
# Prerequisite (recommended): install Elastic Agent Skills from
#   https://github.com/elastic/agent-skills
# then use cloud-setup + cloud-create-project + elasticsearch-authn per SKILLS-FIRST-WORKFLOW.md
#
# Cloud API key: https://cloud.elastic.co/account/keys (Project Admin / Org Owner)
#
# Required: do not leave this empty. Keys often end with "=" — use single quotes:
#   EC_API_KEY='your_key_here'

EC_API_KEY=
EC_BASE_URL=https://api.elastic-cloud.com
EC_REGION=gcp-us-central1

# Optional: lowercase RFC1035-ish prefix for generated project names
A2A_NAME_PREFIX=a2a-lab

# Optional — Agent Builder automation (scripts/05-agent-builder-lab-agents.sh)
# A2A_SKIP_AGENT_BUILDER=1
# AGENT_BUILDER_JS=/absolute/path/to/agent-builder.js
# ELASTIC_AGENT_SKILLS_ROOT=/absolute/path/to/agent-skills-repo-clone
#
# Cross-project Agent Builder HTTP (scripts/02 writes these from bootstrap Kibana URLs; 06 backfills if missing):
# O11Y_AGENT_ENDPOINT=https://YOUR-O11Y.kb.../api/agent_builder/converse
# SECURITY_AGENT_ENDPOINT=https://YOUR-SEC.kb.../api/agent_builder/converse
# For converse URLs, workflows use Basic auth (bootstrap admin). For other URLs, set API keys:
# O11Y_API_KEY=...
# SECURITY_AGENT_API_KEY=...   # or SECURITY_API_KEY
#
# Optional — Kibana Workflows (scripts/06-kibana-workflows-lab.sh, included in run-all.sh)
# Override Kibana targets (defaults: state/bootstrap.json). URL may include /app/… (stripped to API origin).
# A2A_O11Y_KIBANA_URL=https://your-o11y.kb.region.gcp.elastic.cloud/app/workflows
# A2A_O11Y_KIBANA_USER=
# A2A_O11Y_KIBANA_PASSWORD=
# A2A_SEC_KIBANA_URL=https://your-sec.kb.region.gcp.elastic.cloud
# A2A_SEC_KIBANA_USER=
# A2A_SEC_KIBANA_PASSWORD=
# Push only Observability YAML (skip Security block entirely):
# A2A_WORKFLOWS_OBSERVABILITY_ONLY=1
# A2A_SKIP_KIBANA_WORKFLOWS=1
# Skip scheduled workshop ingest workflows (06 still pushes manual + alert-triggered YAML):
# A2A_SKIP_SCHEDULED_SYNTH_WORKFLOWS=1
# Skip manual **Run** synth inject workflows (06 still pushes scheduled + alert YAML):
# A2A_SKIP_MANUAL_SYNTH_WORKFLOWS=1
#
# Optional — lab alerting rules on workshop indices (scripts/07-lab-alert-rules.sh, included in run-all.sh)
# A2A_SKIP_LAB_ALERT_RULES=1
# Lab rule schedule (default 5m — fewer Cases than 1m; e.g. 15m for demos):
# A2A_LAB_RULE_INTERVAL=15m
# Skip auto-attaching **A2A Lab — … alert log** workflow to lab rules in 07 (API uses system-connector-.workflows):
# A2A_SKIP_ATTACH_WORKFLOW_RULE_ACTIONS=1
#
# Optional — scripts/08-synthetic-workflow-test.sh: set to 1 to run Case-creating workflow steps too
# A2A_TEST_WORKFLOWS_INCLUDE_CASES=1
#
# Optional — Dashboards API (scripts/09-lab-dashboards-api.sh, included in run-all.sh)
# A2A_SKIP_LAB_DASHBOARDS=1
#
# Optional — ingest simulator (scripts/10-lab-simulate-traffic.sh; not part of run-all.sh)
# A2A_SKIP_LAB_SIMULATE_TRAFFIC=1
