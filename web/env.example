# Copy to Vercel → Project → Settings → Environment Variables (all environments you deploy).

# Kibana / Serverless project URL, no trailing slash
KIBANA_BASE_URL=https://ai-assistants-ffcafb.kb.us-east-1.aws.elastic.cloud

# Kibana API key with Agent Builder access (feature_agentBuilder.read, etc.)
KIBANA_API_KEY=

# Optional — Agent Builder agent id (UUID) used when the chat UI leaves "Agent id" blank
# KIBANA_AGENT_ID=
