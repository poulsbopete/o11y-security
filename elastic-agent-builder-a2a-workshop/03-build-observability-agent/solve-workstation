#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
TRACK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1090
source "$TRACK_ROOT/scripts/workshop-common.sh"
sync_track_assets "${BASH_SOURCE[0]}"
mkdir -p "$ROOT/artifacts"

cat >"$ROOT/artifacts/o11y-agent-contract.md" <<'EOF'
# Observability context agent — lab contract (solved stub)

- **Method:** POST
- **Auth:** `Authorization: Bearer $O11Y_API_KEY`
- **Body:** `{"host":"<string>","time_range":"1m|5m|15m"}`
- **Response:** JSON per `sample-data/o11y-context-example.json`

Replace this stub with your real Agent Builder URL, authentication, and rate limits before delivering to customers.
EOF

pkill -f o11y_stub_server.py 2>/dev/null || true
chmod +x "$(workshop_root)/scripts/o11y_stub_server.py"
nohup python3 -u "$(workshop_root)/scripts/o11y_stub_server.py" >/tmp/o11y-stub.log 2>&1 &
sleep 1

tmp="$(mktemp)"
if [ -f "$ROOT/.env" ]; then
  grep -v '^O11Y_AGENT_ENDPOINT=' "$ROOT/.env" >"$tmp" || cp "$ROOT/.env" "$tmp"
else
  : >"$tmp"
fi
echo 'O11Y_AGENT_ENDPOINT=http://127.0.0.1:18080/query' >>"$tmp"
mv "$tmp" "$ROOT/.env"
