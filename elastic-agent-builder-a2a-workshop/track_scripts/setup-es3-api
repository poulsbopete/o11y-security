#!/bin/bash
set -euo pipefail

until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
  sleep 1
done

# Only apt-install when missing — speeds hot starts and avoids a long "done" window where
# learners click Start again thinking the lab hung (track setup must finish before play).
if ! command -v nginx >/dev/null 2>&1 || ! command -v curl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1 || ! command -v python3 >/dev/null 2>&1; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get update -y
  apt-get install -y --no-install-recommends curl ca-certificates jq python3 nginx
fi

mkdir -p /root/elastic-workshop/{assets,agent-scaffolds,scripts,sample-data,indices}

_track_yml_ok() {
  local tf="$1"
  [ -f "$tf" ] || return 1
  grep -q 'elastic-a2a-serverless-agent-builder' "$tf" 2>/dev/null && return 0
  grep -qE '^id:[[:space:]]*zq70yyfn826u' "$tf" 2>/dev/null && return 0
  return 1
}

# Challenge lifecycle scripts run from /tmp; resolve the mounted track and copy scripts locally.
TS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
TR=""
if [ -f "$TS_DIR/../scripts/instruqt-track-root.inc.bash" ]; then
  # shellcheck disable=SC1091
  source "$TS_DIR/../scripts/instruqt-track-root.inc.bash"
  TR="$(elastic_workshop_resolve_track_root "${BASH_SOURCE[0]:-$0}")" || TR=""
fi
if [ -z "$TR" ] || [ ! -f "$TR/track.yml" ]; then
  if [ -d /terraform ]; then
    echo "[elastic-workshop] resolving track under /terraform …"
    while IFS= read -r tf; do
      _track_yml_ok "$tf" || continue
      TR="$(dirname "$tf")"
      break
    done < <(find /terraform -maxdepth 40 -type f -name track.yml 2>/dev/null)
  fi
fi
if [ -z "$TR" ] || [ ! -f "$TR/track.yml" ]; then
  echo "[elastic-workshop] resolving track under common roots …"
  while IFS= read -r tf; do
    _track_yml_ok "$tf" || continue
    TR="$(dirname "$tf")"
    break
  done < <(find /opt/instruqt /opt/elastic /opt /var/lib/instruqt /srv /usr/local /home /root /mnt /var/tmp /tmp /usr/share /snap /workspace /challenges -maxdepth 28 -type f -name track.yml 2>/dev/null)
fi
if [ -z "$TR" ] || [ ! -f "$TR/track.yml" ]; then
  while IFS= read -r tf; do
    _track_yml_ok "$tf" || continue
    TR="$(dirname "$tf")"
    break
  done < <(find / -maxdepth 22 -type f -name track.yml 2>/dev/null)
fi
if [ -z "$TR" ] || [ ! -f "$TR/scripts/workshop-common.sh" ]; then
  echo "FATAL: could not resolve workshop track root (missing track or scripts/)." >&2
  echo "FATAL: hint: set ELASTIC_WORKSHOP_TRACK_ROOT for debugging; check /terraform for track.yml." >&2
  exit 1
fi
printf '%s\n' "$TR" >/root/elastic-workshop/.instruqt-track-root
cp -a "$TR/scripts/." /root/elastic-workshop/scripts/
if [ -d "$TR/assets" ]; then
  cp -a "$TR/assets/." /root/elastic-workshop/assets/
fi

rm -f /etc/nginx/sites-enabled/default
cat >/etc/nginx/sites-available/elastic-lab-kibana-proxy.conf <<'STUB'
# Placeholder until learners run scripts/render-kibana-proxy.sh with Kibana URLs in .env
server {
    listen 8080 default_server;
    listen [::]:8080 default_server;
    server_name _;
    default_type text/plain;
    return 503 "Set O11Y_KIBANA_URL and SECURITY_KIBANA_URL in /root/elastic-workshop/.env, then: sudo bash /root/elastic-workshop/scripts/render-kibana-proxy.sh\n";
}
server {
    listen 8081 default_server;
    listen [::]:8081 default_server;
    server_name _;
    default_type text/plain;
    return 503 "Set O11Y_KIBANA_URL and SECURITY_KIBANA_URL in /root/elastic-workshop/.env, then: sudo bash /root/elastic-workshop/scripts/render-kibana-proxy.sh\n";
}
STUB
ln -sf /etc/nginx/sites-available/elastic-lab-kibana-proxy.conf /etc/nginx/sites-enabled/elastic-lab-kibana-proxy.conf
nginx -t
if pgrep -x nginx >/dev/null 2>&1; then
  nginx -s reload
else
  nginx
fi

# Optional: pre-seed .env when Instruqt/org secrets are injected as host env vars (organizer-only).
if [ -n "${O11Y_ES_URL:-}" ] && [ -n "${O11Y_API_KEY:-}" ] && [ -n "${SECURITY_ES_URL:-}" ] && [ -n "${SECURITY_API_KEY:-}" ]; then
  umask 077
  {
    echo "O11Y_ES_URL=${O11Y_ES_URL}"
    echo "O11Y_API_KEY=${O11Y_API_KEY}"
    echo "SECURITY_ES_URL=${SECURITY_ES_URL}"
    echo "SECURITY_API_KEY=${SECURITY_API_KEY}"
    [ -n "${O11Y_KIBANA_URL:-}" ] && echo "O11Y_KIBANA_URL=${O11Y_KIBANA_URL}"
    [ -n "${SECURITY_KIBANA_URL:-}" ] && echo "SECURITY_KIBANA_URL=${SECURITY_KIBANA_URL}"
  } >/root/elastic-workshop/.env
fi

touch /root/elastic-workshop/.workshop-bootstrap-complete
