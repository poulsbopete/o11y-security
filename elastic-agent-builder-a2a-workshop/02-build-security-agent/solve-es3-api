#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
WC="/root/elastic-workshop/scripts/workshop-common.sh"
if [ ! -f "$WC" ]; then
  echo "[workshop] FATAL: expected $WC (track bootstrap copy). Re-provision the sandbox." >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$WC"
sync_track_assets "${BASH_SOURCE[0]}"

if [ ! -f "$ROOT/.env" ]; then
  exit 0
fi

# shellcheck disable=SC1090
set -a
source "$ROOT/.env"
set +a

bash "$ROOT/scripts/apply-index-templates.sh" || true

curl -sS -X POST "${SECURITY_ES_URL}/.elastic-agents-security-detections/_doc?refresh=wait_for" \
  -H "Authorization: ApiKey ${SECURITY_API_KEY}" \
  -H 'Content-Type: application/json' \
  --data-binary @"$ROOT/sample-data/security-detection-example.json" >/dev/null
