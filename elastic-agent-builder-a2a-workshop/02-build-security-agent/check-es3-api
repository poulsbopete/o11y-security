#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
ENV_FILE="$ROOT/.env"
if [ ! -f "$ENV_FILE" ]; then
  fail-message "Missing /root/elastic-workshop/.env — finish Track 1 first."
fi

# shellcheck disable=SC1090
set -a
source "$ENV_FILE"
set +a

body="$(curl -sS --fail -H "Authorization: ApiKey ${SECURITY_API_KEY}" \
  -H 'Content-Type: application/json' \
  "${SECURITY_ES_URL}/.elastic-agents-security-detections/_search" \
  -d '{"size":1,"track_total_hits":true}')" || {
  fail-message "Search against .elastic-agents-security-detections failed. Confirm index exists and API key privileges."
}

total="$(echo "$body" | jq 'if (.hits.total|type)=="object" then .hits.total.value else .hits.total end')"
if ! [[ "${total:-0}" =~ ^[0-9]+$ ]] || [ "${total:-0}" -lt 1 ]; then
  fail-message "No documents in .elastic-agents-security-detections yet. Run the Security agent or click Skip to load the sample document."
fi

echo "Security detections index contains at least one document."
