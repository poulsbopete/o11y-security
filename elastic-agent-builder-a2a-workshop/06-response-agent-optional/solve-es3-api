#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
WC="/root/elastic-workshop/scripts/workshop-common.sh"
if [ ! -f "$WC" ]; then
  echo "[workshop] FATAL: expected $WC (track bootstrap copy). Re-provision the sandbox." >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$WC"
sync_track_assets "${BASH_SOURCE[0]}"
mkdir -p "$ROOT/artifacts"
printf '%s\n' "integration" "Solved stub: Slack connector narrative captured for facilitators." >"$ROOT/artifacts/response-track-choice.txt"
