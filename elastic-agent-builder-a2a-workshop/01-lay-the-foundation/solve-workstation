#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
umask 077
mkdir -p "$ROOT"

TRACK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1090
source "$TRACK_ROOT/scripts/workshop-common.sh"
sync_track_assets "${BASH_SOURCE[0]}"
cp -f "$TRACK_ROOT/assets/env.template" "$ROOT/env.template"

if [ -n "${O11Y_ES_URL:-}" ] && [ -n "${O11Y_API_KEY:-}" ] && [ -n "${SECURITY_ES_URL:-}" ] && [ -n "${SECURITY_API_KEY:-}" ]; then
  cat >"$ROOT/.env" <<EOF
O11Y_ES_URL=${O11Y_ES_URL}
O11Y_API_KEY=${O11Y_API_KEY}
SECURITY_ES_URL=${SECURITY_ES_URL}
SECURITY_API_KEY=${SECURITY_API_KEY}
EOF
  bash "$ROOT/scripts/apply-index-templates.sh" || true
  bash "$ROOT/scripts/load-sample-bulk.sh" || true
fi
