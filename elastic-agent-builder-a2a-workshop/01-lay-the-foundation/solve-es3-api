#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
umask 077
mkdir -p "$ROOT"

# Resolve track root: Instruqt copies lifecycle scripts to /tmp; see track_scripts/setup-es3-api.
TRACK_ROOT=""
if [ -f /root/elastic-workshop/.instruqt-track-root ]; then
  TRACK_ROOT="$(head -1 /root/elastic-workshop/.instruqt-track-root | tr -d '\r\n')"
fi
if [ -z "${TRACK_ROOT:-}" ] || [ ! -f "$TRACK_ROOT/scripts/workshop-common.sh" ]; then
  while IFS= read -r tf; do
    grep -q 'elastic-a2a-serverless-agent-builder' "$tf" 2>/dev/null || continue
    TRACK_ROOT="$(dirname "$tf")"
    break
  done < <(find /opt/instruqt /root /srv /var/tmp -maxdepth 14 -type f -name track.yml 2>/dev/null)
fi
if [ -z "${TRACK_ROOT:-}" ] || [ ! -f "$TRACK_ROOT/scripts/workshop-common.sh" ]; then
  TRACK_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi
# shellcheck disable=SC1090
source "$TRACK_ROOT/scripts/workshop-common.sh"
sync_track_assets "${BASH_SOURCE[0]}"
cp -f "$TRACK_ROOT/assets/env.template" "$ROOT/env.template"

if [ -n "${O11Y_ES_URL:-}" ] && [ -n "${O11Y_API_KEY:-}" ] && [ -n "${SECURITY_ES_URL:-}" ] && [ -n "${SECURITY_API_KEY:-}" ]; then
  umask 077
  {
    echo "O11Y_ES_URL=${O11Y_ES_URL}"
    echo "O11Y_API_KEY=${O11Y_API_KEY}"
    echo "SECURITY_ES_URL=${SECURITY_ES_URL}"
    echo "SECURITY_API_KEY=${SECURITY_API_KEY}"
    [ -n "${O11Y_KIBANA_URL:-}" ] && echo "O11Y_KIBANA_URL=${O11Y_KIBANA_URL}"
    [ -n "${SECURITY_KIBANA_URL:-}" ] && echo "SECURITY_KIBANA_URL=${SECURITY_KIBANA_URL}"
  } >"$ROOT/.env"
  if [ -n "${O11Y_KIBANA_URL:-}" ] && [ -n "${SECURITY_KIBANA_URL:-}" ]; then
    bash "$ROOT/scripts/render-kibana-proxy.sh" "$ROOT/.env" || true
  fi
  bash "$ROOT/scripts/apply-index-templates.sh" || true
  bash "$ROOT/scripts/load-sample-bulk.sh" || true
fi
