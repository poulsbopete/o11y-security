#!/bin/bash
set -euo pipefail

ROOT="/root/elastic-workshop"
ENV_FILE="$ROOT/.env"

if [ ! -f "$ENV_FILE" ]; then
  fail-message "Create /root/elastic-workshop/.env from env.template with your two Elasticsearch URLs and API keys."
fi

# shellcheck disable=SC1090
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

for var in O11Y_ES_URL O11Y_API_KEY O11Y_KIBANA_URL SECURITY_ES_URL SECURITY_API_KEY SECURITY_KIBANA_URL; do
  if [ -z "${!var:-}" ]; then
    fail-message "Missing ${var} in /root/elastic-workshop/.env"
  fi
done

proxy_ok() {
  local port="$1"
  local name="$2"
  local code
  code=$(curl -sS -o /dev/null -w "%{http_code}" --max-time 20 "http://127.0.0.1:${port}/" || echo "000")
  case "$code" in
    503|000)
      fail-message "${name} Kibana proxy (:${port}) is still the lab placeholder (HTTP ${code}). Set O11Y_KIBANA_URL and SECURITY_KIBANA_URL in .env, then run: sudo bash /root/elastic-workshop/scripts/render-kibana-proxy.sh"
      ;;
  esac
}

proxy_ok 8080 "Observability"
proxy_ok 8081 "Security"

check_health() {
  local url="$1"
  local key="$2"
  local label="$3"
  local body
  if ! body="$(curl -sS --fail -H "Authorization: ApiKey ${key}" "${url}/_cluster/health")"; then
    fail-message "${label}: HTTP request to _cluster/health failed. Confirm URL and API key."
  fi
  if ! echo "$body" | jq -e '.status' >/dev/null 2>&1; then
    fail-message "${label}: unexpected JSON from _cluster/health."
  fi
  local status
  status="$(echo "$body" | jq -r '.status')"
  case "$status" in
    green|yellow) ;;
    *)
      fail-message "${label}: cluster status is ${status} (expected green or yellow)."
      ;;
  esac
}

check_health "$O11Y_ES_URL" "$O11Y_API_KEY" "Observability"
check_health "$SECURITY_ES_URL" "$SECURITY_API_KEY" "Security"

echo "Both clusters reachable with healthy status."
