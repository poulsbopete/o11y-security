#!/bin/bash
set -euo pipefail

WC="/root/elastic-workshop/scripts/workshop-common.sh"
if [ ! -f "$WC" ]; then
  echo "[workshop] FATAL: expected $WC (track bootstrap copy). Re-provision the sandbox." >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$WC"

sync_track_assets "${BASH_SOURCE[0]}"
mkdir -p "$(workshop_root)/artifacts"
cp -f "$(workshop_root)/assets/env.template" "$(workshop_root)/env.template"

ENV_FILE="$(workshop_root)/.env"
if [ -f "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  if [ -n "${O11Y_KIBANA_URL:-}" ] && [ -n "${SECURITY_KIBANA_URL:-}" ]; then
    bash "$(workshop_root)/scripts/render-kibana-proxy.sh" "$ENV_FILE"
  fi
fi
