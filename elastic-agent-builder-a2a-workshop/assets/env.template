# Copy to /root/elastic-workshop/.env and fill from your two Serverless projects.
# Use the Elasticsearch endpoint (HTTPS) and an API key with minimal privileges for this lab.

O11Y_ES_URL=https://YOUR-O11Y-PROJECT.es.region.aws.elastic.cloud:443
O11Y_API_KEY=YOUR_O11Y_BASE64_API_KEY
O11Y_KIBANA_URL=https://YOUR-O11Y-PROJECT.kb.region.aws.elastic.cloud:443

SECURITY_ES_URL=https://YOUR-SECURITY-PROJECT.es.region.aws.elastic.cloud:443
SECURITY_API_KEY=YOUR_SECURITY_BASE64_API_KEY
SECURITY_KIBANA_URL=https://YOUR-SECURITY-PROJECT.kb.region.aws.elastic.cloud:443

# Optional: Observability Agent HTTP endpoint (Track 3+) — Agent Builder external URL or proxy.
O11Y_AGENT_ENDPOINT=https://YOUR-O11Y_AGENT_ENDPOINT/query
